{
    "pluginAlias": "MyHome",
    "pluginType": "platform",
    "schema": {
        "type": "object",
        "properties": {
            "name": {
                "title": "Name",
                "type": "string",
                "required": true,
                "default": "MyHome"
            },
            "host": {
                "title": "MyHome server address",
                "type": "string",
                "required": true,
                "default": "192.168.1.35"
            },
            "port": {
                "title": "MyHome server port",
                "type": "integer",
                "required": false,
                "default": 20000
            },
            "password": {
                "title": "MyHome server password",
                "type": "string",
                "required": false,
                "default": ""
            },
            "lights": {
                "title": "Lights",
                "buttonText": "Add Light",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "type": "integer",
                            "required": true
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        },
                        "dimmer": {
                            "title": "Dimmer",
                            "description": "Enable dimmer support (brightness levels 2-10)",
                            "type": "boolean",
                            "required": false,
                            "default": false
                        }
                    }
                }
            },
            "blinds": {
                "title": "Blinds",
                "buttonText": "Add blind",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "type": "integer",
                            "required": true
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        },
                        "time": {
                            "title": "Travel time (s)",
                            "description": "Time in seconds for full linear travel (up or down)",
                            "type": "integer",
                            "required": true
                        },
                        "timeSlat": {
                            "title": "Slat rotation time (s)",
                            "description": "Additional time in seconds for slat rotation (venetian blinds only, leave 0 for roller blinds)",
                            "type": "integer",
                            "required": false,
                            "default": 0
                        },
                        "slatPercent": {
                            "title": "Slat threshold (%)",
                            "description": "Position (%) below which slat rotation occurs. E.g. 10 means: 10%=blind down slats open, 0%=fully closed. Leave 0 for roller blinds.",
                            "type": "integer",
                            "required": false,
                            "default": 0
                        }
                    }
                }
            },
            "thermostats": {
                "title": "Thermostats",
                "buttonText": "Add Thermostat",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "type": "integer",
                            "required": true
                        },
                        "zone": {
                            "title": "zone",
                            "type": "integer",
                            "required": true
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        }
                    }
                }
            },
            "scenarios": {
                "title": "Scenarios",
                "buttonText": "Add Scenario",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "description": "Scenario number (WHO=0)",
                            "type": "integer",
                            "required": true
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        }
                    }
                }
            },
            "contacts": {
                "title": "Dry Contacts",
                "buttonText": "Add Contact",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "description": "Auxiliary/dry contact address (WHO=9)",
                            "type": "integer",
                            "required": true
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        }
                    }
                }
            },
            "energies": {
                "title": "Energy Monitors",
                "buttonText": "Add Energy Monitor",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "description": "Energy meter address (WHO=18)",
                            "type": "integer",
                            "required": true
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        }
                    }
                }
            }
        }
    }
}