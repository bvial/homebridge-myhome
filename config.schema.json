{
    "pluginAlias": "MyHome",
    "pluginType": "platform",
    "schema": {
        "type": "object",
        "properties": {
            "name": {
                "title": "Name",
                "type": "string",
                "required": true,
                "default": "MyHome"
            },
            "host": {
                "title": "MyHome server address",
                "type": "string",
                "required": true,
                "default": "192.168.1.35"
            },
            "port": {
                "title": "MyHome server port",
                "type": "integer",
                "required": false,
                "minimum": 1,
                "maximum": 65535,
                "default": 20000
            },
            "password": {
                "title": "MyHome server password",
                "type": "string",
                "required": false,
                "default": "",
                "description": "Numeric password for OWN authentication (decimal integer; leave empty if no password)"
            },
            "maxConcurrent": {
                "title": "Max concurrent commands",
                "description": "Optional override for the max simultaneous TCP command connections (1–10). If omitted the plugin queries the gateway model and sets it automatically.",
                "type": "integer",
                "required": false,
                "minimum": 1,
                "maximum": 10
            },
            "autoDiscover": {
                "title": "Auto-discover devices",
                "description": "Scan the gateway for devices not in config and register them automatically as placeholder accessories. Restart Homebridge to re-run the scan.",
                "type": "boolean",
                "required": false,
                "default": false
            },
            "autoDiscoverMaxAddr": {
                "title": "Auto-discover max address",
                "description": "Maximum address (1..N) probed per WHO type during auto-discovery. Higher values find more devices but take longer. Default: 20.",
                "type": "integer",
                "required": false,
                "minimum": 1,
                "maximum": 99,
                "default": 20
            },
            "lights": {
                "title": "Lights",
                "buttonText": "Add Light",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "type": "integer",
                            "required": true,
                            "minimum": 1
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        },
                        "dimmer": {
                            "title": "Dimmer",
                            "description": "Enable dimmer support (brightness levels 2-10)",
                            "type": "boolean",
                            "required": false,
                            "default": false
                        },
                        "where": {
                            "title": "Custom WHERE address",
                            "description": "Optional raw OpenWebNet WHERE address for special relay configurations (e.g. \"68#4#01\"). Defaults to id.",
                            "type": "string",
                            "required": false
                        }
                    }
                }
            },
            "blinds": {
                "title": "Blinds",
                "buttonText": "Add blind",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "type": "integer",
                            "required": true,
                            "minimum": 1
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        },
                        "time": {
                            "title": "Travel time (s)",
                            "description": "Time in seconds for full linear travel (up or down)",
                            "type": "integer",
                            "required": true,
                            "minimum": 1
                        },
                        "timeSlat": {
                            "title": "Slat rotation time (s)",
                            "description": "Additional time in seconds for slat rotation (venetian blinds only, leave 0 for roller blinds)",
                            "type": "integer",
                            "required": false,
                            "minimum": 0,
                            "default": 0
                        },
                        "slatPercent": {
                            "title": "Slat threshold (%)",
                            "description": "Position (%) below which slat rotation occurs. E.g. 10 means: 10%=blind down slats open, 0%=fully closed. Leave 0 for roller blinds.",
                            "type": "integer",
                            "required": false,
                            "minimum": 0,
                            "maximum": 100,
                            "default": 0
                        },
                        "calibrateOnStart": {
                            "title": "Calibrate on start",
                            "description": "Move the blind fully down on first Homebridge start to establish a known position. Set to false to restore the last cached position without moving (useful if you don't want blinds to move on every restart).",
                            "type": "boolean",
                            "required": false,
                            "default": true
                        },
                        "inverted": {
                            "title": "Invert direction",
                            "description": "Default true (BTicino convention: *2*1* = DOWN, *2*2* = UP). Set to false if HomeKit shows 'opening' while the blind closes (reverse-wired installation).",
                            "type": "boolean",
                            "required": false,
                            "default": true
                        }
                    }
                }
            },
            "thermostats": {
                "title": "Thermostats",
                "buttonText": "Add Thermostat",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "type": "integer",
                            "required": true,
                            "minimum": 1
                        },
                        "zone": {
                            "title": "zone",
                            "type": "integer",
                            "required": true,
                            "minimum": 1
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        }
                    }
                }
            },
            "scenarios": {
                "title": "Scenarios",
                "buttonText": "Add Scenario",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "description": "Scenario number (WHO=0)",
                            "type": "integer",
                            "required": true,
                            "minimum": 1
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        },
                        "asButton": {
                            "title": "Expose as button",
                            "description": "Use Stateless Programmable Switch instead of Switch (better for momentary actions; may break existing automations)",
                            "type": "boolean",
                            "required": false,
                            "default": false
                        }
                    }
                }
            },
            "contacts": {
                "title": "Dry Contacts",
                "buttonText": "Add Contact",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "description": "Auxiliary/dry contact address (WHO=9)",
                            "type": "integer",
                            "required": true,
                            "minimum": 1
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        },
                        "sensorType": {
                            "title": "Sensor type",
                            "description": "How HomeKit displays this dry contact",
                            "type": "string",
                            "required": false,
                            "default": "contact",
                            "oneOf": [
                                { "title": "Contact (door/window)", "enum": ["contact"] },
                                { "title": "Motion (PIR)", "enum": ["motion"] },
                                { "title": "Occupancy", "enum": ["occupancy"] },
                                { "title": "Leak", "enum": ["leak"] },
                                { "title": "Smoke", "enum": ["smoke"] },
                                { "title": "Carbon Monoxide", "enum": ["co"] }
                            ]
                        }
                    }
                }
            },
            "energies": {
                "title": "Energy Monitors",
                "buttonText": "Add Energy Monitor",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "description": "Energy meter address (WHO=18)",
                            "type": "integer",
                            "required": true,
                            "minimum": 1
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        },
                        "asOutlet": {
                            "title": "Expose as outlet",
                            "description": "Use Outlet service with Eve Consumption characteristic instead of LightSensor lux-hack (better Eve.app support)",
                            "type": "boolean",
                            "required": false,
                            "default": false
                        }
                    }
                }
            },
            "doors": {
                "title": "Door / Video Door (intercom)",
                "buttonText": "Add door",
                "type": "array",
                "items": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "title": "id",
                            "description": "Door entry / video door address (WHO=7)",
                            "type": "integer",
                            "required": true,
                            "minimum": 1
                        },
                        "name": {
                            "title": "Name",
                            "type": "string",
                            "required": false
                        },
                        "openCommand": {
                            "title": "OWN open command",
                            "description": "OWN command to send to release the door (defaults to *7*19*<id>##)",
                            "type": "string",
                            "required": false
                        },
                        "doorbell": {
                            "title": "Expose as Doorbell too",
                            "description": "Adds a linked Doorbell service that fires SINGLE_PRESS when an incoming call is received on the bus",
                            "type": "boolean",
                            "required": false,
                            "default": false
                        }
                    }
                }
            }
        }
    }
}
